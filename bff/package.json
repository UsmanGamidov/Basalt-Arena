{
  "name": "bff",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "VITEST_PROJECT=unit vitest run",
    "test:unit": "VITEST_PROJECT=unit vitest run",
    "test:integration": "INTEGRATION=1 VITEST_PROJECT=integration vitest run",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@testcontainers/postgresql": "^11.14.0",
    "argon2": "^0.41.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "ioredis-mock": "^8.9.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "supertest": "^7.1.3",
    "testcontainers": "^10.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
