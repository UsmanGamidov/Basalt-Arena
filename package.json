{
  "name": "basalt-arena",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client",
    "build:render": "npm run build -w client && npm run prisma:generate -w server && npm run build -w server",
    "start": "npm run start -w server",
    "test": "node --test client/src/lib/adminSubmissions.test.js client/src/lib/adminSolutions.test.js client/src/lib/sprintIds.test.js",
    "test:server:health": "node scripts/test-server-health.mjs",
    "test:server:api": "node scripts/test-server-api.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "dependencies": {
    "json": "^11.0.0",
    "openai": "^6.34.0",
    "os": "^0.1.2",
    "requests": "^0.3.0"
  }
}
