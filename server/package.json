{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:prepare": "prisma generate && prisma db push",
    "start": "node dist/main.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "bootstrap:admin:remote": "prisma generate --schema=prisma/schema.postgres.prisma && node scripts/bootstrap-admin.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:push:postgres": "prisma db push --schema=prisma/schema.postgres.prisma",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.8.2",
    "@types/bcrypt": "^6.0.0",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.1.8",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.8.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
