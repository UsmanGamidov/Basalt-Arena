# Порт HTTP-сервера NestJS
PORT=3001

# Уровень структурных логов (pino): fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# Локально (по умолчанию): SQLite в server/prisma/dev.db
DATABASE_URL="file:./dev.db"

# Продакшен (Render + Supabase): Session pooler URI
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# JWT секрет для access token
JWT_SECRET="REPLACE_WITH_64+_CHAR_RANDOM_SECRET"

# Dev-ключ для регистрации через mock API (заголовок x-dev-register-key)
BASALT_DEV_REGISTER_KEY="REPLACE_WITH_STRONG_DEV_KEY"

# Локально:
# BASALT_CORS_ORIGIN=http://localhost:5173
# На Render:
# BASALT_CORS_ORIGIN=https://your-app.onrender.com

# Метаданные для GET /v2/meta (опционально)
# BASALT_APP_BUILD=basalt-arena@1.0.0
# BASALT_PRIZE_POOL_SHORT=120K
# BASALT_PRIZE_CURRENCY=₽

# Bootstrap админа: npm run bootstrap:admin -w server
# Для Supabase с ПК: npm run bootstrap:admin:remote -w server (нужен postgres DATABASE_URL в .env)
# BASALT_BOOTSTRAP_ADMIN_HANDLE=admin
# BASALT_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BASALT_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
